{
  "version": 1,
  "project": {
    "id": "music-analyzer-daw",
    "name": "MusicAnalyzerDAW",
    "vision": "Structure-aware song builder for deconstructing existing songs into reusable pattern graphs and creating new songs by editing or generating canonical blocks.",
    "audience": {
      "primary": "internal_solo_tool",
      "secondary": [
        "research_dataset_tool"
      ]
    },
    "status": "alpha",
    "current_state": {
      "summary": "Working prototype with MIDI upload, piano-roll analysis/editing, pattern tree logic, dataset export, dataset browsing, and local ABC/WAV rendering.",
      "strengths": [
        "MIDI upload and per-song analysis flow works",
        "Rich client-side pattern editing logic already exists",
        "Training/example export pipeline already exists",
        "Local rendering pipeline already exists"
      ],
      "risks": [
        "monolithic_backend",
        "monolithic_editor_frontend",
        "no_dependency_manifest",
        "no_test_harness",
        "flat_file_schema_drift",
        "synchronous_rendering"
      ]
    }
  },
  "milestones": [
    {
      "id": "m1",
      "name": "Foundation Stabilization",
      "status": "in_progress",
      "priority": "critical",
      "target_window": "short_term",
      "goal": "Make the current prototype safe to evolve by reducing architectural risk and formalizing the current data contracts.",
      "epics": [
        {
          "id": "m1e1",
          "name": "Backend modularization",
          "status": "in_progress",
          "tasks": [
            {
              "id": "m1e1t1",
              "name": "Split route concerns out of app.py",
              "status": "in_progress",
              "depends_on": [],
              "verification": [
                "Root, upload, view, dataset, settings, and render flows still work"
              ]
            },
            {
              "id": "m1e1t2",
              "name": "Introduce shared services for MIDI parsing and render orchestration",
              "status": "planned",
              "depends_on": [
                "m1e1t1"
              ]
            }
          ]
        },
        {
          "id": "m1e2",
          "name": "Frontend modularization",
          "status": "planned",
          "tasks": [
            {
              "id": "m1e2t1",
              "name": "Split piano-roll state, rendering, pattern graph, and playback concerns",
              "status": "planned",
              "depends_on": []
            },
            {
              "id": "m1e2t2",
              "name": "Preserve current behavior during refactor",
              "status": "planned",
              "depends_on": [
                "m1e2t1"
              ]
            }
          ]
        },
        {
          "id": "m1e3",
          "name": "Data contract formalization",
          "status": "planned",
          "tasks": [
            {
              "id": "m1e3t1",
              "name": "Add versioned schemas for user settings and training examples",
              "status": "planned",
              "depends_on": []
            },
            {
              "id": "m1e3t2",
              "name": "Standardize relationship metadata across exported examples",
              "status": "planned",
              "depends_on": [
                "m1e3t1"
              ]
            }
          ]
        }
      ]
    },
    {
